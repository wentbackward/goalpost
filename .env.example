# --- Postgres (shared instance for Postiz + Collector) ---
POSTGRES_USER=social
POSTGRES_PASSWORD=changeme
POSTGRES_DB=social_analytics

# --- Postiz ---
MAIN_URL=http://localhost:3060
NEXT_PUBLIC_BACKEND_URL=http://localhost:3060/api
DATABASE_URL=postgresql://social:changeme@postgres:5432/social_analytics
REDIS_URL=redis://redis:6379
JWT_SECRET=changeme_jwt_secret
POSTIZ_API_KEY=                    # Set after first run; found in Postiz Settings

# --- Collector ---
COLLECTOR_DATABASE_URL=postgresql+asyncpg://social:changeme@postgres:5432/social_analytics
COLLECTOR_API_KEY=changeme_collector_key

# --- Postiz bridge mode: db or api ---
POSTIZ_BRIDGE_MODE=db

# --- OAuth callback URI (for LinkedIn/Meta token generation scripts) ---
REDIRECT_URI=https://your-hostname:9090/callback

# --- Postiz social media app credentials (for connecting accounts in Postiz UI) ---
X_API_KEY=
X_API_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
THREADS_APP_ID=
THREADS_APP_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
OPENAI_API_KEY=

# --- Collector platform credentials (for pulling analytics) ---

# X / Twitter — requires Twitter Developer App (Basic tier minimum for read)
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=             # Long-lived token (60 days); refresh manually

# Instagram — Meta Graph API; requires Business/Creator account linked to FB Page
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Facebook — Meta Graph API; Page access token
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# YouTube — Google Cloud project with YouTube Data API v3 enabled
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=
